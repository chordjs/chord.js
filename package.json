{
  "name": "chord.js",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=\"./packages/*\"",
    "build:cli": "bun run --cwd packages/cli build",
    "docs:build": "typedoc",
    "dev": "bun run --cwd packages/core dev",
    "dev:bot": "bun run --cwd examples/basic-bot dev",
    "dev:scaling": "bun run --cwd examples/folder-routing-sharding dev",
    "test": "bun test packages/core/tests packages/gateway/tests packages/rest/tests packages/utils/tests packages/cache/tests",
    "typecheck": "turbo run typecheck --filter=\"./packages/*\"",
    "clean": "turbo run clean --filter=\"./packages/*\"",
    "changeset": "bunx changeset",
    "version-packages": "bunx changeset version",
    "release": "bunx changeset publish"
  },
  "license": "MIT",
  "author": "Agent0876 <Agent0876@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chordjs/chord.js.git"
  },
  "bugs": {
    "url": "https://github.com/chordjs/chord.js/issues"
  },
  "homepage": "https://github.com/chordjs/chord.js#readme",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "turbo": "latest",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@types/node": "25.6.0",
    "bun-types": "latest",
    "chokidar": "^5.0.0",
    "typedoc": "^0.26.0",
    "typedoc-plugin-markdown": "^4.1.0"
  }
}
