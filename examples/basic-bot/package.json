{
  "name": "@chordjs/example-basic-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/main.ts",
    "start": "bun run src/main.ts",
    "build": "bun build ./src/main.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chordjs/core": "workspace:*",
    "@chordjs/gateway": "workspace:*",
    "@chordjs/rest": "workspace:*"
  }
}
