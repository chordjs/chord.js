{
  "name": "@chordjs/cli",
  "version": "26.3.0",
  "description": "The official CLI for Chord.js framework.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chordjs/chord.js.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/chordjs/chord.js/tree/main/packages/cli#readme",
  "type": "module",
  "bin": {
    "chord": "./dist/index.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo template",
    "build": "rm -rf dist tsconfig.tsbuildinfo template && mkdir -p template && cp -r ../../examples/basic-bot/* template/ && bunx swc src -d dist --strip-leading-paths --config-file ../../.swcrc && bunx tsc -p tsconfig.json --emitDeclarationOnly --declaration --declarationMap --outDir dist && chmod +x dist/index.js",
    "dev": "bunx swc src -d dist --strip-leading-paths --watch --config-file ../../.swcrc",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0",
    "execa": "^8.0.1",
    "enquirer": "^2.4.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "25.6.0",
    "typescript": "6.0.3"
  }
}
