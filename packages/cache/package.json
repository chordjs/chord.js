{
  "name": "@chordjs/cache",
  "version": "26.0.2",
  "description": "In-memory cache layer for Chord.js.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chordjs/chord.js.git",
    "directory": "packages/cache"
  },
  "homepage": "https://github.com/chordjs/chord.js/tree/main/packages/cache#readme",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "rm -rf dist tsconfig.tsbuildinfo && bunx swc src -d dist --strip-leading-paths --config-file ../../.swcrc && bunx tsc -p tsconfig.json --emitDeclarationOnly --declaration --declarationMap --outDir dist",
    "dev": "bunx swc src -d dist --strip-leading-paths --watch --config-file ../../.swcrc",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@chordjs/types": "workspace:*",
    "@chordjs/utils": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
