{
  "name": "@chordjs/framework",
  "version": "26.8.10",
  "description": "Umbrella framework package for Chord.js",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "rm -rf dist tsconfig.tsbuildinfo && bunx swc src -d dist --strip-leading-paths --config-file ../../.swcrc && bunx tsc -p tsconfig.json --emitDeclarationOnly --declaration --declarationMap --outDir dist",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@chordjs/builders": "^26.8.10",
    "@chordjs/cache": "^26.8.10",
    "@chordjs/collection": "^26.8.10",
    "@chordjs/core": "^26.8.10",
    "@chordjs/gateway": "^26.8.10",
    "@chordjs/i18n": "^26.8.10",
    "@chordjs/interactions": "^26.8.10",
    "@chordjs/logger": "^26.8.10",
    "@chordjs/metrics": "^26.8.10",
    "@chordjs/rest": "^26.8.10",
    "@chordjs/types": "^26.8.10",
    "@chordjs/utils": "^26.8.10",
    "@chordjs/voice": "^26.8.10",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@swc/cli": "^0.3.12",
    "@swc/core": "^1.5.7",
    "typescript": "6.0.3"
  },
  "author": "shinseungmin",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}